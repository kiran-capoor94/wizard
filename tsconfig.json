{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./build",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    "data/**/*.ts",
    "interfaces/**/*.ts",
    "shared/**/*.ts",
    "llm/**/*.ts",
    "services/**/*.ts",
    "integrations/**/*.ts",
    "core/**/*.ts",
    "security/**/*.ts"
  ],
  "exclude": ["node_modules", "build", "generated", "tests"]
}
