{
  "name": "wizard",
  "version": "2.2.0",
  "db": "~/.wizard/wizard.db",
  "jira": {
    "base_url": "https://yourorg.atlassian.net",
    "project_key": "ENG",
    "token": "your-jira-api-token"
  },
  "notion": {
    "daily_page_id": "notion-daily-page-id",
    "tasks_db_id": "your-notion-tasks-database-id",
    "meetings_db_id": "your-notion-meetings-database-id",
    "token": "your-notion-integration-token"
  },
  "scrubbing": {
    "enabled": true,
    "allowlist": ["SISU", "AUTH-\\d+", "ENG-\\d+"]
  },
  "synthesis": {
    "model": "ollama/gemma4:latest-64k",
    "base_url": "http://localhost:11434",
    "api_key": "",
    "enabled": true
  },
  "sentry": {
    "dsn": "your-sentry-dsn-here",
    "enabled": false,
    "traces_sample_rate": 0.1,
    "profiles_sample_rate": 0.1
  }
}
