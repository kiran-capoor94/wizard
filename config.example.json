{
  "name": "wizard",
  "version": "1.1.0",
  "db": "/home/<you>/.wizard/wizard.db",
  "jira": {
    "base_url": "https://yourorg.atlassian.net",
    "project_key": "ENG",
    "token": "your-jira-api-token"
  },
  "notion": {
    "daily_page_id": "notion-page-id-here",
    "token": "your-notion-integration-token"
  },
  "krisp": {
    "api_base_url": "https://api.krisp.ai",
    "token": "your-krisp-api-token"
  },
  "scrubbing": {
    "enabled": true,
    "allowlist": ["SISU", "AUTH-\\d+", "ENG-\\d+"]
  }
}
